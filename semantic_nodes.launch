<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <param name="/use_sim_time" value="true"/>

  <!-- ARGUMENTS with defaults -->
  <arg name="azure_timeout_sec" default="25.0" />
  <arg name="max_recipes" default="3" />
  <arg name="ingredient_conf_threshold" default="0.3" />
  <arg name="ingredient_publish_rate" default="1.0" />

  <!-- Pass Azure env vars into node processes (roslaunch picks from host env) -->
  <env name="AZURE_OPENAI_KEY" value="$(env AZURE_OPENAI_KEY)"/>
  <env name="AZURE_OPENAI_ENDPOINT" value="$(env AZURE_OPENAI_ENDPOINT)"/>
  <env name="AZURE_OPENAI_DEPLOYMENT" value="$(env AZURE_OPENAI_DEPLOYMENT)"/>
  <env name="AZURE_OPENAI_API_VERSION" value="$(env AZURE_OPENAI_API_VERSION)"/>

  <!-- Optional: small params (set from args) -->
  <param name="~azure_timeout_sec" value="$(arg azure_timeout_sec)" />
  <param name="~max_recipes" value="$(arg max_recipes)" />
  <param name="~ingredient_conf_threshold" value="$(arg ingredient_conf_threshold)" />
  <param name="~ingredient_publish_rate" value="$(arg ingredient_publish_rate)" />

  <!-- ingredient recognition: publishes /detected_ingredients -->
  <node pkg="empower_nodes" type="ingredient_recognition.py" name="ingredient_recognition" output="screen" respawn="false">
    <param name="~conf_threshold" value="$(arg ingredient_conf_threshold)" />
    <param name="~publish_rate" value="$(arg ingredient_publish_rate)" />
  </node>

  <!-- semantic chef -->
  <node pkg="empower_nodes" type="semantic_chef.py" name="semantic_chef" output="screen" respawn="false">
    <param name="~azure_timeout_sec" value="$(arg azure_timeout_sec)" />
    <param name="~max_recipes" value="$(arg max_recipes)" />
  </node>

  <!-- semantic voice node: listens /voice_commands and publishes /move_base_simple/goal -->
  <node pkg="empower_nodes" type="semantic_voice_node.py" name="semantic_voice_node" output="screen" respawn="false" />

  <!-- NOTE: heavier helpers are not started here -->
</launch>
